# Sample environment file for Moosify
# Do NOT commit the real values!
# All three keys are optional – omit them if you want to run the pure local fallback.
CEREBRAS_API_KEY="your_cerebras_key"
GROQ_API_KEY="your_groq_key"
TOGETHER_API_KEY="your_together_key"
# Optional: set OPENAI_MODEL if you want to use OpenAI fallback
OPENAI_MODEL="gpt-5.5"
# Set CHAT_STATUS to "down" to disable chat UI (useful for maintenance)
CHAT_STATUS="up"
